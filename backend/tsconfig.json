{
    "compilerOptions": {
        "target": "es2025",
        "module": "esnext",
        "moduleResolution": "nodenext",
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "declaration": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}